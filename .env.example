# Homelab Configuration
# Copy this file to .env and configure with your values

# =============================================================================
# REQUIRED: Base Domain Configuration
# =============================================================================

# Your main domain name - all services will use subdomains of this
BASE_DOMAIN=your-domain.com

# =============================================================================
# REQUIRED: Cloudflare DNS Configuration
# =============================================================================
# Required for automatic SSL certificate generation via DNS challenge
# Get these from your Cloudflare account: https://dash.cloudflare.com/profile/api-tokens
CF_Token=your_cloudflare_api_token_here

# =============================================================================
# OPTIONAL: Docker User Configuration
# =============================================================================
# Set these to match your user to avoid permission issues with mounted volumes
# Run: id $(whoami) to get your values
UID=1000
GID=1000

# =============================================================================
# REQUIRED: SSH Configuration
# =============================================================================
# SSH key used by Ansible and all homelab scripts.
# Generate:   task ansible:ssh:generate
# Distribute: task ansible:ssh:distribute
SSH_KEY_FILE=~/.ssh/homelab_rsa

# =============================================================================
# DEV ENVIRONMENT
# =============================================================================
# Git identity used for commits made inside the devbox container.
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=you@example.com

# =============================================================================
# NETWORK INFRASTRUCTURE
# =============================================================================
# NAS server hostname/IP for SMB/CIFS volumes and SSH access
NAS_SERVER=nas.your-domain.com

# NAS SSH username (used by Kiwix setup script)
NAS_USER=admin

# SSH key used by cert-sync-nas to install TLS certs on the NAS via OMV RPC.
# Defaults to ~/.ssh/homelab_rsa. Set this to a dedicated NAS-only key
# if you want to limit the key's access scope (recommended).
#CERT_SYNC_SSH_KEY_FILE=~/.ssh/cert_sync_rsa

# NAS IP address (used for iSCSI target)
NAS_IP=192.168.1.x

# Local network subnet (for VPN container firewall - allows local network access)
LOCAL_SUBNET=192.168.1.0/24

# =============================================================================
# STORAGE & NETWORK CREDENTIALS
# =============================================================================
# SMB/CIFS storage credentials for network volumes
SMB_USERNAME=your_smb_username
SMB_PASSWORD=your_secure_smb_password
SMB_DOMAIN=your_domain

# =============================================================================
# iSCSI / OCFS2 CONFIGURATION
# =============================================================================
# Shared block storage for Docker volumes (optional)
ISCSI_ENABLED=false
ISCSI_TARGET_PORT=3260
ISCSI_TARGET_IQN=iqn.xxxx-xx.com.example.nas:target-name
ISCSI_MOUNT_PATH=/mnt/iscsi/media-apps

ISCSI_APP_DATA_ENABLED=false
ISCSI_APP_DATA_IQN=iqn.xxxx-xx.com.example.nas:app-data
ISCSI_APP_DATA_MOUNT_PATH=/mnt/iscsi/app-data

ISCSI_CACHE_ENABLED=false
ISCSI_CACHE_IQN=iqn.xxxx-xx.com.example.nas:cache
ISCSI_CACHE_MOUNT_PATH=/mnt/iscsi/cache

# =============================================================================
# DATABASE CREDENTIALS
# =============================================================================
# PhotoPrism database credentials
PHOTOPRISM_ADMIN_PASSWORD=your_secure_photoprism_admin_password
PHOTOPRISM_DB_PASSWORD=your_secure_photoprism_db_password
MARIADB_ROOT_PASSWORD=your_secure_mariadb_root_password

# Immich database credentials
IMMICH_DB_PASSWORD=your_secure_immich_db_password
IMMICH_DB_USERNAME=postgres
IMMICH_DB_DATABASE_NAME=immich
IMMICH_VERSION=release

# Shared PostgreSQL password (LibreChat, Forgejo, Authentik)
POSTGRES_PASSWORD=your_secure_postgres_password

# LibreNMS database credentials
LIBRENMS_DB_PASSWORD=your_secure_librenms_db_password

# =============================================================================
# BACKUP CONFIGURATION (Kopia)
# =============================================================================
# Repository password (used to encrypt/decrypt backup data in Backblaze B2)
KOPIA_PASSWORD=your_secure_kopia_repository_password

# Web UI authentication
KOPIA_SERVER_USERNAME=admin
KOPIA_SERVER_PASSWORD=your_secure_kopia_server_password

# =============================================================================
# MONITORING & ADMIN INTERFACES
# =============================================================================
# Grafana admin credentials
GRAFANA_ADMIN_PASSWORD=your_secure_grafana_admin_password

# =============================================================================
# DNS SERVER CONFIGURATION
# =============================================================================
# PRIMARY_DNS_MANAGED=true:  this repo deploys and manages the DNS server (stacks/dns)
# PRIMARY_DNS_MANAGED=false: bring your own DNS — set PRIMARY_DNS_HOST to your server
PRIMARY_DNS_TYPE=technitium
PRIMARY_DNS_MANAGED=true
PRIMARY_DNS_API_KEY=your_secure_dns_admin_password
# Required when PRIMARY_DNS_MANAGED=false
#PRIMARY_DNS_HOST=192.168.1.x

# DNS server upstream forwarders (comma-separated, Technitium only)
DNS_SERVER_FORWARDERS=1.1.1.1,1.0.0.1

# Secondary DNS configuration
# Enable to keep a secondary DNS server in sync so services resolve when the primary is down
# Supported types: pihole (requires v6.3+, uses REST API at http://<host>/api)
# IMPORTANT: Pi-hole must have app_sudo enabled to allow API writes:
#   sudo pihole-FTL --config webserver.api.app_sudo true
SECONDARY_DNS_ENABLED=false
SECONDARY_DNS_TYPE=pihole
SECONDARY_DNS_HOST=192.168.1.x
SECONDARY_DNS_API_KEY=your_secondary_dns_api_password

# =============================================================================
# TIMEZONE CONFIGURATION
# =============================================================================
TZ=UTC

# =============================================================================
# VPN CONFIGURATION
# Downloads stack (OpenVPN)
# Get service credentials from: nordvpn.com/account → Services → Manual setup → OpenVPN
DOWNLOADS_VPN_SERVICE_PROVIDER=nordvpn
DOWNLOADS_VPN_TYPE=openvpn
DOWNLOADS_OPENVPN_USER=your_nordvpn_service_username
DOWNLOADS_OPENVPN_PASSWORD=your_nordvpn_service_password
DOWNLOADS_VPN_SERVER_COUNTRIES=Netherlands
DOWNLOADS_VPN_SERVER_CATEGORIES=P2P
DOWNLOADS_VPN_SERVER_CITIES=
DOWNLOADS_DOCKER_SUBNET=172.18.0.0/16

# Kenku (manga downloader) Postgres database
DOWNLOADS_KENKU_DB_USER=kenku
DOWNLOADS_KENKU_DB_NAME=kenku
DOWNLOADS_KENKU_DB_PASSWORD=change_me

# Tor browser stack (WireGuard) — always separate credentials.
# WireGuard uses a cryptographic keypair, not a username/password, so it
# cannot share the OpenVPN creds above regardless of provider.
#
# Supported providers: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
# Mullvad: generate at https://mullvad.net/en/account/wireguard-config
# ProtonVPN: export from https://account.proton.me/u/0/vpn/WireGuard
TOR_VPN_SERVICE_PROVIDER=mullvad
TOR_VPN_SERVER_COUNTRIES=Switzerland
TOR_WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here
TOR_WIREGUARD_ADDRESSES=10.x.x.x/32

# KasmVNC password — Authentik handles auth at the Traefik layer,
# but kasmweb requires a non-empty VNC password internally.
# Generate with: openssl rand -base64 16
TOR_BROWSER_VNC_PASSWORD=your_secure_vnc_password_here

# =============================================================================
# AI/LLM API KEYS (for LibreChat)
# =============================================================================
GROQ_API_KEY=your_groq_api_key
MISTRAL_API_KEY=your_mistral_api_key
OPENROUTER_KEY=your_openrouter_api_key
PORTKEY_API_KEY=your_portkey_api_key
PORTKEY_OPENAI_VIRTUAL_KEY=your_portkey_virtual_key
TTS_API_KEY=your_text_to_speech_api_key
STT_API_KEY=your_speech_to_text_api_key

# =============================================================================
# CONTAINER REGISTRY (for Docker Swarm)
# =============================================================================
# GitHub credentials — GITHUB_USERNAME doubles as the GHCR namespace for all stacks
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Takeout Manager images (ghcr.io/<namespace>/takeout-manager, takeout-worker)
TAKEOUT_MANAGER_REGISTRY_URL=ghcr.io
TAKEOUT_MANAGER_REGISTRY_NAMESPACE=your-github-username
TAKEOUT_MANAGER_IMAGE_TAG=latest

# Monitoring images (ghcr.io/<namespace>/iperf3-server, iperf3-exporter)
# MONITORING_REGISTRY_NAMESPACE defaults to GITHUB_USERNAME if unset
MONITORING_REGISTRY_URL=ghcr.io
MONITORING_REGISTRY_NAMESPACE=your-github-username
MONITORING_IMAGE_TAG=latest

# Warden — quota-aware *arr hunter (image defaults to ghcr.io/chutch3/warden:latest).
# Configure whichever *arr instances you run; omit a URL/KEY pair to disable that one.
# Find each API key in the *arr UI under Settings > General > Security.
WARDEN_RADARR_URL=http://radarr:7878
WARDEN_RADARR_API_KEY=
WARDEN_SONARR_URL=http://sonarr:8989
WARDEN_SONARR_API_KEY=
# Optional tuning (defaults shown): reserve % held back for manual/other use, the
# daily search budget used when Prowlarr isn't wired (Phase 1), local reset time, poll.
WARDEN_RESERVE_PCT=20
WARDEN_FALLBACK_SEARCHES_PER_DAY=200
WARDEN_RESET_AT_LOCAL=00:00
WARDEN_POLL_INTERVAL_SEC=300
# Optional Prowlarr integration: derive each source's daily budget from real
# per-indexer query limits. Omit to pace against WARDEN_FALLBACK_SEARCHES_PER_DAY.
WARDEN_PROWLARR_URL=http://prowlarr:9696
WARDEN_PROWLARR_API_KEY=
# Assumed daily query cap for indexers Prowlarr leaves "unlimited" (nothing is truly unlimited).
WARDEN_DEFAULT_QUERY_LIMIT=100
# Timezone for the daily quota reset window (defaults to the container TZ, then UTC).
WARDEN_TZ=
# When Prowlarr is unreachable: true = fall back to the flat budget and keep hunting;
# false = let the tick fail and retry (no hunting until Prowlarr returns).
WARDEN_PROWLARR_FALLBACK_ON_ERROR=true

# Stale-queue sweep (Phase 2): remove + blocklist downloads *arr has flagged
# stalled/errored past the grace window, and exclude in-queue items from hunting.
WARDEN_STALE_SWEEP_ENABLED=true
WARDEN_STALE_GRACE_HOURS=48
WARDEN_STALE_MAX_REMOVALS_PER_TICK=5
WARDEN_STALE_MASS_FRACTION=0.5
WARDEN_STALE_MIN_QUEUE_FOR_GUARD=3

# =============================================================================
# AUTHENTIK (Identity Provider)
# =============================================================================
AUTHENTIK_POSTGRES_PASSWORD=your_secure_authentik_db_password

# Generate with: openssl rand -base64 36
AUTHENTIK_SECRET_KEY=your_authentik_secret_key

# Outpost tokens (generated in Authentik UI after creating outposts)
AUTHENTIK_OUTPOST_TOKEN=
AUTHENTIK_LDAP_TOKEN=

# OIDC Client Credentials (create in Authentik: Applications > Providers > OAuth2/OpenID)
GRAFANA_OAUTH_CLIENT_ID=
GRAFANA_OAUTH_CLIENT_SECRET=

IMMICH_OAUTH_CLIENT_ID=
IMMICH_OAUTH_CLIENT_SECRET=

MEALIE_OAUTH_CLIENT_ID=
MEALIE_OAUTH_CLIENT_SECRET=

VAULTWARDEN_OAUTH_CLIENT_ID=
VAULTWARDEN_OAUTH_CLIENT_SECRET=

FORGEJO_OAUTH_CLIENT_ID=
FORGEJO_OAUTH_CLIENT_SECRET=

FRESHRSS_OAUTH_CLIENT_ID=
FRESHRSS_OAUTH_CLIENT_SECRET=
# Generate with: openssl rand -base64 32
FRESHRSS_OAUTH_CRYPTO_KEY=
# Traefik overlay network subnet — default covers Docker Swarm overlay ranges
FRESHRSS_TRUSTED_PROXY=10.0.0.0/8

# =============================================================================
# FRESHRSS (RSS Feed Aggregator)
# =============================================================================
# Default admin user — must match the preferred_username claim from Authentik
FRESHRSS_DEFAULT_USER=admin
FRESHRSS_ADMIN_PASSWORD=your_secure_freshrss_admin_password
FRESHRSS_ADMIN_API_PASSWORD=your_secure_freshrss_api_password
FRESHRSS_ADMIN_EMAIL=your_email@example.com

# =============================================================================
# FORGEJO (Git Service)
# =============================================================================
FORGEJO_VERSION=10-rootless
FORGEJO_SSH_PORT=2222
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=your_secure_forgejo_db_password
FORGEJO_DB_NAME=forgejo

# =============================================================================
# ORCHESTRATION (Prefect)
# =============================================================================
PREFECT_DB_PASSWORD=your_secure_prefect_db_password

# =============================================================================
# CI/CD RUNNERS (GitHub & Forgejo)
# =============================================================================
# GitHub Runner (for github.com actions)
GITHUB_REPO=homelab
GITHUB_RUNNER_TOKEN=your_github_runner_registration_token

# Forgejo Runner (for git.${BASE_DOMAIN} actions)
# Runner registration token (get from Forgejo Admin > Actions > Runners)
FORGEJO_RUNNER_TOKEN=your_forgejo_runner_token_here

# =============================================================================
# ACTUAL BUDGET MCP SERVER
# =============================================================================
ACTUAL_PASSWORD=your_actual_budget_password
ACTUAL_BUDGET_SYNC_ID=your_actual_budget_sync_id
ACTUAL_BUDGET_ENCRYPTION_PASSWORD=your_actual_budget_encryption_password_if_different

EXCALIDRAW_DB_PASSWORD=changeme

# =============================================================================
# STATUS PIPELINE (public service status via MinIO + Tailscale Funnel)
# =============================================================================
# Pushes Uptime Kuma status data to a MinIO bucket on the NAS, exposed via
# Tailscale Funnel for the portfolio site to fetch.
#
# Setup:
#   1. Set STATUS_PIPELINE_MINIO_ACCESS_KEY/SECRET_KEY and STATUS_PIPELINE_STATUS_SLUG
#   2. Upload tailscale-acl-policy.json to Tailscale admin (adds tag:homelab-nas + Funnel)
#   3. Run: scripts/status-pipeline/setup-nas-tailscale.sh (install Tailscale on NAS)
#   4. Run: task status-pipeline:setup (deploys sync script + cron to NAS)
#   5. Run: task status-pipeline:funnel:on (enables public Funnel endpoint)
#   6. Set STATUS_PIPELINE_URL below with the Funnel URL
#   7. Run: task status-pipeline:verify
#   8. Update prometheus.yml with your NAS_SERVER for MinIO metrics (optional)

# Uptime Kuma status page slug (the URL-safe name from Uptime Kuma → Status Pages)
STATUS_PIPELINE_STATUS_SLUG=homelab

# Set to true to enable MinIO metrics scraping in Prometheus.
# When enabled, STATUS_PIPELINE_MINIO_METRICS_TOKEN must also be set.
STATUS_PIPELINE_MINIO_ENABLED=false

# MinIO credentials (OMV MinIO root user)
STATUS_PIPELINE_MINIO_ACCESS_KEY=admin
STATUS_PIPELINE_MINIO_SECRET_KEY=your_minio_password

# MinIO host:port (used by Prometheus scraping and Funnel backend)
STATUS_PIPELINE_MINIO_HOST=nas.your-domain.com:9000

# MinIO Prometheus bearer token
# Generate: ssh root@NAS "podman exec minio-app mc admin prometheus generate local cluster"
# Regenerate if you change the MinIO password
STATUS_PIPELINE_MINIO_METRICS_TOKEN=

# Public Funnel URL for the status JSON (used by verify task)
# Set after running: task status-pipeline:funnel:on
# Format: https://<tailscale-hostname>.<tailnet>.ts.net/public-status/status.json
STATUS_PIPELINE_URL=

# =============================================================================
# OPTIONAL: Tailscale VPN
# =============================================================================
# Enables remote access to each cluster node via its own Tailscale IP (100.x.x.x).
# No subnet routes are advertised by default — your broader LAN is not exposed.
#
# Setup:
#   1. Create an auth key at https://login.tailscale.com/admin/settings/keys
#      - Enable: Reusable, Ephemeral: off, Pre-authorized: on
#      - Tags: tag:homelab-server  (must exist in your Tailscale ACL policy first)
#   2. Upload docs/tailscale-acl-policy.json to https://login.tailscale.com/admin/acls
#   3. Set TAILSCALE_ENABLED=true and paste the key below
#   4. Run: task ansible:tailscale:configure
#
# OPNsense note: when your firewall arrives, transfer subnet routing to its
# Tailscale plugin and leave TAILSCALE_ADVERTISE_ROUTES empty here.
TAILSCALE_ENABLED=false
TAILSCALE_AUTH_KEY=tskey-auth-your-key-here
# Optional: comma-separated CIDRs to advertise (leave empty for node-only access)
TAILSCALE_ADVERTISE_ROUTES=
