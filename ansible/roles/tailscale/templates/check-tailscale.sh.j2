#!/bin/bash
# Managed by Ansible — do not edit manually
LOG_FILE="{{ tailscale_health_check_log }}"
MAX_LOG_BYTES=10485760  # 10 MB

# Rotate log if it exceeds max size
if [ -f "$LOG_FILE" ] && [ "$(stat -c%s "$LOG_FILE")" -gt "$MAX_LOG_BYTES" ]; then
    mv "$LOG_FILE" "${LOG_FILE}.1"
fi

if systemctl is-active --quiet tailscaled && tailscale status >/dev/null 2>&1; then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] INFO: Tailscale healthy on $(hostname)" >> "$LOG_FILE"
    exit 0
else
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: Tailscale issue detected on $(hostname), restarting tailscaled" >> "$LOG_FILE"
    systemctl restart tailscaled
    exit 1
fi
