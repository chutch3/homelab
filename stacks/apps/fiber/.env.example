# Fiber — label-driven database dump manager
# Image (matches stacks/apps/fiber/Taskfile.yml)
FIBER_REGISTRY_URL=ghcr.io
FIBER_REGISTRY_NAMESPACE=chutch3
FIBER_IMAGE_TAG=latest

# From the shared/root env: BASE_DOMAIN, TZ

# Optional engine tuning (sensible defaults baked into the image):
# FIBER_DEFAULT_SCHEDULE=0 3 * * *
# FIBER_DEFAULT_RETAIN=7
# FIBER_MAX_CONCURRENT_MOVEMENTS=2
# FIBER_SCAN_INTERVAL=60
